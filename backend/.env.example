# ----------------------------------------
# Flowlet Backend - Environment Variables
# ----------------------------------------

# Server
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# CORS - origin do front
CORS_ORIGIN=http://localhost:4200

# Database (PostgreSQL)
# Local via docker-compose:
DATABASE_URL="postgresql://flowlet:flowlet@localhost:5432/flowlet?schema=public"
# Quando for usar Supabase, pegar em Project Settings > Database > Connection string (URI):
# DATABASE_URL="postgresql://postgres:[SUA-SENHA]@db.[SEU-REF].supabase.co:5432/postgres"

# JWT - troque em producao
JWT_SECRET="troque-isso-em-producao-use-uma-string-aleatoria-longa-de-no-minimo-32-chars"
JWT_EXPIRES_IN="7d"

# Public URL (para webhooks)
PUBLIC_URL="http://localhost:3333"
